{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ruyi-serving.local/models.schema.json",
  "title": "Ruyi Serving Model Registry",
  "type": "object",
  "required": [
    "models"
  ],
  "properties": {
    "models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "tool"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Public model identifier exposed by /v1/models."
          },
          "owned_by": {
            "type": "string",
            "description": "Public owner metadata."
          },
          "created": {
            "type": "integer",
            "description": "Unix epoch timestamp exposed through model discovery."
          },
          "serving": {
            "type": "object",
            "properties": {
              "api_mode": {
                "type": "string",
                "enum": [
                  "chat",
                  "completion",
                  "both"
                ]
              },
              "prompt_style": {
                "type": "string",
                "enum": [
                  "buddy_deepseek_r1",
                  "chatml",
                  "raw_completion"
                ]
              },
              "default_max_tokens": {
                "type": "integer",
                "minimum": 1
              },
              "max_max_tokens": {
                "type": "integer",
                "minimum": 1
              },
              "max_input_chars": {
                "type": "integer",
                "minimum": 1
              },
              "request_timeout_ms": {
                "type": "integer",
                "minimum": 1
              },
              "stream_idle_timeout_s": {
                "type": "integer",
                "minimum": 1
              },
              "allow_anonymous_models": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          },
          "tool": {
            "type": "object",
            "required": [
              "cli_path"
            ],
            "properties": {
              "cli_path": {
                "type": "string",
                "description": "Absolute path to the real model CLI executable."
              },
              "numactl_nodes": {
                "type": "string"
              },
              "taskset_cpus": {
                "type": "string"
              },
              "extra_args": {
                "type": "string",
                "description": "Additional production CLI flags."
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
